{
  "name": "@tefi/design-system",
  "version": "0.4.22",
  "type": "module",

  "files": [
    "dist"
  ],

  "main": "./dist/tefi-design-system.umd.cjs",
  "module": "./dist/tefi-design-system.js",

  "types": "./dist/src/index.d.ts",

  "style": "./dist/tefi-design-system.css",

  "sideEffects": [
    "**/*.css"
  ],

  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/tefi-design-system.js",
      "require": "./dist/tefi-design-system.umd.cjs"
    },

    "./styles.css": "./dist/tefi-design-system.css"
  },

  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },

  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },

  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0"
  },

  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.1",
    "globals": "^17.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.4.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  }
}